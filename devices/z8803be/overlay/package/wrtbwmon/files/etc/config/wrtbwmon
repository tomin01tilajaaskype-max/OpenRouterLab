config general 'general'
	option enabled '0'
	option domain_tracking '1'
	option db_file '/etc/wrtbwmon/traffic.db'
	option interface 'br-lan'
	option db_keep_days '90'
	option cleanup_enabled '1'
	option cleanup_inactive_days '90'
	option domain_cache_ttl '604800'
	option dns_backend 'auto'
	option log_level 'info'
