config general 'general'
	option enabled '1'
	option network_title 'WiFi network'
	option cache_file '/tmp/wifi-clients-cache.json'
	option cache_max_age '60'
	option refresh_interval '30'
	option ssh_key '/root/.ssh/id_dropbear'
	option ssh_connect_timeout '3'

config router 'local'
	option enabled '1'
	option name 'Local'
	option host 'localhost'
	option label 'Local Router'
	option sort_order '100'
