uci -q delete dhcp.@dnsmasq[0].server
uci -q add_list dhcp.@dnsmasq[0].server='127.0.0.1#5454'
uci -q set dhcp.@dnsmasq[0].cachesize='1000'
uci -q set dhcp.@dnsmasq[0].localise_queries='1'
uci -q set dhcp.@dnsmasq[0].expandhosts='1'
uci -q set dhcp.@dnsmasq[0].domain='lan'
uci -q set dhcp.@dnsmasq[0].local='/lan/'
uci -q set dhcp.@dnsmasq[0].filter_aaaa='1'
uci -q set dhcp.@dnsmasq[0].logqueries='0'
uci -q commit dhcp

if ! uci -q get adguardhome.config >/dev/null 2>&1; then
	uci -q set adguardhome.config='adguardhome'
