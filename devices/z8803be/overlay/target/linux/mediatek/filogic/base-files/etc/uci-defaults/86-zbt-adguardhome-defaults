#!/bin/sh
set -e

case "$(cat /tmp/sysinfo/board_name 2>/dev/null)" in
	zbtlink,zbt-z8803be|zbtlink,zbt-z8803be,mt7988a-nand) ;;
	*) exit 0 ;;
esac

APK_DIR=/usr/share/zbt/apk

install_adguardhome() {
	if apk info -e adguardhome >/dev/null 2>&1 && apk info -e luci-app-adguardhome >/dev/null 2>&1; then
		return 0
	fi

	set -- "$APK_DIR"/adguardhome-*.apk "$APK_DIR"/luci-app-adguardhome-*.apk
	if [ -f "$1" ] && [ -f "$2" ]; then
		apk add --allow-untrusted --force-non-repository "$1" "$2"
		return 0
	fi

	apk update
	apk add adguardhome luci-app-adguardhome
}

install_adguardhome

sed -i '/# DoH-bootstrap-pinned/d' /etc/hosts
cat >> /etc/hosts <<'HOSTS'
172.64.41.4 mozilla.cloudflare-dns.com # DoH-bootstrap-pinned
162.159.61.4 mozilla.cloudflare-dns.com # DoH-bootstrap-pinned
45.90.28.0 dns.nextdns.io # DoH-bootstrap-pinned
