#!/bin/sh /etc/rc.common
# Procd watchdog that keeps cellular failover alive.
#
# Background:
#   FUjr/QModem's modem_scan.sh and qmodem_init have a race during boot:
#   /etc/config/qmodem and /etc/config/network get rewritten a few
#   seconds after our 40-zbt-qmodem-autoenable hotplug sets things up,
#   flipping qmodem.4_1.state back to 'disabled', wiping the
#   network.4_1 / 4_1v6 stubs, and dropping '4_1' / '4_1v6' off the
#   firewall wan-zone network list. Net effect: LAN clients see "no
#   internet" while the router itself still pings out.
#
#   The exact qmodem write-site is buried inside its lock+scan logic.
#   Rather than fight upstream, this watchdog runs forever and re-asserts
#   all three pieces (state, stubs, zone membership) on a poll cycle.
#
# Implementation:
#   The poll body lives in /usr/sbin/zbt-qmodem-watchdog-loop (separate
#   file so we can test it from CLI and so we avoid the shell-quoting
#   bombs that come with inlining a multi-line loop into
#   `procd_set_param command sh -c '...'`).
#
#   Cadence is fast (5 s) for the first 60 s after start, slow (30 s)
#   after. Procd reload triggers also wake us immediately on edits to
#   firewall / network / qmodem UCI files, so reactivity is sub-second
#   on the actual write events that cause trouble.
#
# Disable: /etc/init.d/zbt_qmodem_watchdog disable

START=99
STOP=10
USE_PROCD=1

NAME=zbt-qmodem-watchdog
PROG=/usr/sbin/zbt-qmodem-watchdog-loop

# Board guard: the watchdog only makes sense on hardware that has the
# qmodem cellular slot (Z8803BE). Other ZBT/MTK builds reusing this
# base-files tree would otherwise spam the log with "no qmodem.4_1
# section" warnings.
board_match() {
	case "$(cat /tmp/sysinfo/board_name 2>/dev/null)" in
		zbtlink,zbt-z8803be|zbtlink,zbt-z8803be,mt7988a-nand) return 0 ;;
		*) return 1 ;;
	esac
}

start_service() {
	board_match || return 0
	[ -x "$PROG" ] || return 0

	procd_open_instance "$NAME"
	procd_set_param command "$PROG"
	# Respawn aggressively if the loop ever exits (it shouldn't - it's
	# a `while :;` - but procd reload-triggers SIGTERM us, so we need
	# clean restart semantics). 5 5 0 = 5 s threshold, 5 s timeout,
	# infinite retries.
	procd_set_param respawn 5 5 0
	# stdout/stderr -> logread alongside our explicit `logger` calls.
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	# Wake the loop immediately when any of the three configs we watch
	# is written. Without this, the worst-case window between a qmodem
	# rewrite and our re-assert is POLL_INTERVAL_FAST seconds (5 s by
	# default during boot, 30 s after FAST_PHASE_SECS expires); with
	# this trigger, procd SIGTERMs the loop and respawns it within
	# milliseconds of the offending uci commit.
	procd_add_reload_trigger qmodem network firewall
}
